# piperd environment file — copy to /etc/piper/piperd.env (mode 0600).
# Every value below is optional; the defaults shown match piperd's built-in
# defaults. Uncomment and edit only what you need to override.
#
# PIPER_DATA_DIR, XDG_DATA_HOME and XDG_CONFIG_HOME are set by the systemd unit
# (piperd.service) to /var/lib/piper — do not set them here.

# --- Control plane (LAN-only, Plan 1) ---
# Control API listen address (the piper CLI talks to this). The default binds
# loopback only; set 0.0.0.0:8088 to reach it from another machine on the LAN.
#PIPER_API_ADDR=127.0.0.1:8088
# Apps are served at <name>.<PIPER_BASE_DOMAIN>.
#PIPER_BASE_DOMAIN=piper.localhost
# Caddy admin API base URL (embedded Caddy).
#PIPER_CADDY_ADMIN=http://127.0.0.1:2019

# --- Relay + public TLS (Plan 2; leave unset for LAN-only) ---
# Relay tunnel endpoint. Empty => LAN-only, no outbound tunnel.
#PIPER_RELAY_ADDR=
# Enrollment token presented to the relay.
#PIPER_RELAY_TOKEN=
# Loopback listener for GitHub webhooks (relay mode).
#PIPER_WEBHOOK_ADDR=127.0.0.1:8089
# ACME account email and DNS-01 provider for public certificates.
#PIPER_ACME_EMAIL=
#PIPER_DNS_PROVIDER=cloudflare
# Override the ACME directory (e.g. staging); empty => Let's Encrypt production.
#PIPER_ACME_CA=
