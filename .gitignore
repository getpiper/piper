# dependencies / builds
node_modules/
dist/
build/
bin/
*.exe

# secrets / env
.env
.env.*
!.env.example
deploy/compose/piperd.env

# local state
*.sqlite
*.sqlite-*
*.db

# os / editor
.DS_Store
*.log

# superpowers brainstorming sessions
.superpowers/
.worktrees/

# claude code: ignore local state, keep shared project config committable.
# Must be `.claude/*`, not `.claude/` — a trailing-slash rule excludes the
# directory itself, and git never descends into it, so the `!` lines below
# would silently do nothing.
.claude/*
!.claude/settings.json
!.claude/agents/
!.claude/skills/
!.claude/workflows/
