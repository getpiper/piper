# piperd environment file (Linux rootless) — copy to ~/.piper/piperd.env.
# Read by the systemd user unit (piperd.user.service) via EnvironmentFile, so
# anything set here overrides the unit's defaults. Every value is optional;
# defaults shown match piperd's built-ins.
#
# The user unit pins XDG_DATA_HOME/XDG_CONFIG_HOME to ~/.piper/piperd so Caddy
# stores its data alongside piperd's, and relocates the Caddy admin to :2020 so
# a rootless instance doesn't collide with a system piperd. PIPER_DATA_DIR
# defaults to ~/.piper/piperd — set it here only to relocate the SQLite DB.

# --- Control plane (LAN-only) ---
# Control API the piper CLI talks to (loopback by default).
#PIPER_API_ADDR=127.0.0.1:8088
# Apps are served at <name>.<PIPER_BASE_DOMAIN>.
#PIPER_BASE_DOMAIN=piper.localhost
# Caddy admin API base URL (the user unit sets this to :2020, off the system
# piperd's default :2019).
#PIPER_CADDY_ADMIN=http://127.0.0.1:2020

# --- Listen ports (rootless: high ports, no privilege needed) ---
# The user unit defaults these to :8080/:8443. Apps are reachable at
# http://<name>.piper.localhost:8080.
#PIPER_HTTP_ADDR=:8080
#PIPER_HTTPS_ADDR=:8443

# --- Docker ---
# piperd reaches Docker via /var/run/docker.sock by default. If your Docker
# socket lives elsewhere, point piperd at it (or set it via the docker group):
#DOCKER_HOST=unix:///run/user/1000/docker.sock
